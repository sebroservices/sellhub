# ─── eBay Developer App ───────────────────────────────────────────────────────
# Get these from https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REDIRECT_URI=http://localhost:3000/auth/ebay/callback
EBAY_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sellhub
DB_USER=postgres
DB_PASSWORD=your-db-password

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Demo mode (no eBay account needed) ──────────────────────────────────────
# Set to true to auto-login and use seeded mock data
DEMO_MODE=false

# ─── Email alerts (optional — uses nodemailer) ────────────────────────────────
# Works with Gmail, Mailgun, SendGrid, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=your@gmail.com
