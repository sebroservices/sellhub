{
  "name": "sellhub",
  "version": "1.0.0",
  "description": "eBay seller management platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "db:migrate": "node backend/db/migrate.js",
    "db:seed": "node backend/demo/seedDemo.js",
